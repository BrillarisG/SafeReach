# SafeReach backend environment template.
# Copy to backend/.env locally and fill real values. Do not commit real secrets.

SAFE_REACH_ENV=development
SAFE_REACH_RELOAD=false
SECRET_KEY=change-this-secret
JWT_SECRET=change-this-jwt-secret
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# Required only when running backend/scripts/seed.py. Keep real test values in backend/.env.
SEED_MAIN_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_PARENT_PASSWORD=

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VERCEL_ORIGIN_SUFFIX=.vercel.app
SOCKETIO_CORS_ORIGINS=*

# DB-1 editable operational store
DB1_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# DB-2 append-only audit/backup store
DB2_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# DB-3 realtime/event/log store
MONGODB_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/safereach2026?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=safereach2026

# Redis cache/queue/session/rate-limit store
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BOOTSTRAP_CACHE_SECONDS=60

# Google Sheets schema export
GOOGLE_SERVICE_ACCOUNT_FILE=../API/safereach-499510-547d074a1ae9.json
GOOGLE_SHEET_ID=1720rZslTQRxHjiXJtp4AoKUZ59rik0f9YcICWe4MqXg

# Twilio SMS. For development, use your own test number only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_TEST_TO_PHONE=
SMS_TEST_MODE=true

# Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=SafeReach <noreply@safereach.local>

# Sentry
SENTRY_DSN=

# JSON backup export folder. Generated backups should be stored on a protected disk path.
JSON_BACKUP_DIR=backend/json_backups
