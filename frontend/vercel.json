  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "env": {
    "VITE_SAFEREACH_API_URL": "https://safereach-backend-olac.onrender.com/api/v1",
    "VITE_SAFEREACH_WS_URL": "https://safereach-backend-olac.onrender.com"
  }
}
